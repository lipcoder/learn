{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Go: Debug current folder",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}",
      "cwd": "${fileDirname}",
      "console": "integratedTerminal",
      "args": ["${input:url}"],
      "env": {}
    }
  ],
  "inputs": [
    {
      "id": "url",
      "type": "promptString",
      "description": "请输入启动参数（可留空）"
    }
  ]
}